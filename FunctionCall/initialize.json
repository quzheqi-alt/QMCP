{
  "description": "初始化连接 - 客户端发送 initialize 请求以协商协议版本和能力",
  "request": {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "initialize",
    "params": {
      "protocolVersion": "2025-03-26",
      "capabilities": {
        "roots": { "listChanged": true }
      },
      "clientInfo": {
        "name": "test-client",
        "version": "1.0.0"
      }
    }
  },
  "expectedResponse": {
    "jsonrpc": "2.0",
    "id": 1,
    "result": {
      "protocolVersion": "2025-03-26",
      "capabilities": {
        "tools": { "listChanged": true },
        "resources": { "subscribe": false, "listChanged": true },
        "prompts": { "listChanged": true }
      },
      "serverInfo": {
        "name": "mcp-server",
        "version": "1.0.0"
      }
    }
  }
}
