  "request": {
    "jsonrpc": "2.0",
    "id": 9,
    "method": "prompts/list",
    "params": {}
  },
  "expectedResponse": {
    "jsonrpc": "2.0",
    "id": 9,
    "result": {
      "prompts": [
        {
          "name": "greeting",
          "description": "生成一段个性化的问候语",
