{
  "description": "向 Session 存储数据 - 写入 key-value，后续请求可读取",
  "request": {
    "jsonrpc": "2.0",
    "id": 20,
    "method": "tools/call",
    "params": {
      "name": "store_set",
      "arguments": {
        "key": "username",
        "value": "野崎"
      }
    }
  },
  "expectedResponse": {
    "jsonrpc": "2.0",
    "id": 20,
    "result": {
      "content": [
        {
          "type": "text",
          "text": "已存储: username = \"野崎\"\n当前 store 共 1 个键"
        }
      ]
    }
  }
}
